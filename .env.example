# =============================================================================
# Telegram Bot
# =============================================================================

# Bot token from @BotFather
BOT_TOKEN=123456789:AAGASD2cxfatkDasDE22dqfawdfawd2WD-UI

# Your personal Telegram ID (used as developer/admin account)
BOT_DEV_ID=123456789

# Forum supergroup where support topics are created (must be a supergroup with Topics enabled)
BOT_GROUP_ID=-100123456789

# Custom emoji IDs for topic icons (get them from @getmyid_bot or similar)
# Used to visually indicate the topic state in the support group
BOT_EMOJI_ID=5417915203100613993
MANAGER_EMOJI_ID=5417915203100613993
START_EMOJI_ID=5417915203100613993
BAN_EMOJI_ID=5417915203100613993

# =============================================================================
# Topic Status Display
# =============================================================================

# If true: show status as a text prefix in the topic title (e.g. "🆕 | John Doe")
# If false: change the topic custom emoji icon instead
TOPIC_STATUS_IN_TITLE=false

# Fixed emoji ID applied to ALL topics when TOPIC_STATUS_IN_TITLE=true (leave empty to use BOT_EMOJI_ID)
TOPIC_FIXED_EMOJI_ID=

# Status emoji prefixes (used only when TOPIC_STATUS_IN_TITLE=true)
TOPIC_STATUS_EMOJI_START=🆕
TOPIC_STATUS_EMOJI_USER=✅
TOPIC_STATUS_EMOJI_MANAGER=🤖
TOPIC_STATUS_EMOJI_BAN=⛔

# =============================================================================
# Language
# =============================================================================

# Set to false to disable multi-language support and always use DEFAULT_LANGUAGE
MULTI_LANGUAGE=true

# Default language used when MULTI_LANGUAGE=false or user has no language set
# Supported values: ru, en
DEFAULT_LANGUAGE=ru

# =============================================================================
# Redis
# =============================================================================

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# =============================================================================
# Access Control
# =============================================================================

# Comma-separated Telegram user IDs that are allowed to run support commands
# (/ban, /silent, /close, /info, /archive, /help, etc.)
# Example: SUPPORT_ADMIN_IDS=123456789,987654321
SUPPORT_ADMIN_IDS=

# =============================================================================
# Data Storage (SQLite files — mount these as Docker volumes)
# =============================================================================

# Dialogue archive: stores all user <-> support messages as plain text
DIALOGUE_SQLITE_PATH=.data/dialogues.sqlite3

# User/topic state: source of truth for topic IDs, ban status, etc.
USER_STATE_SQLITE_PATH=.data/user_state.sqlite3

# =============================================================================
# Cleanup Jobs (background job that removes stale topics)
# =============================================================================

# How often to run the cleanup job (minutes)
CLEANUP_BLOCKED_TOPICS_INTERVAL_MINUTES=720

# Delete topics for banned/blocked users older than N days
CLEANUP_BLOCKED_TOPICS_OLDER_THAN_DAYS=14

# Delete topics with no messages at all older than N days
CLEANUP_EMPTY_TOPICS_OLDER_THAN_DAYS=14

# Max topics processed per cleanup run
CLEANUP_BLOCKED_TOPICS_BATCH_SIZE=50

# Telegram rate-limit protection (increase if you see RetryAfter errors during cleanup)
CLEANUP_TG_CALL_MIN_INTERVAL_SECONDS=0.25
CLEANUP_TG_SEND_MIN_INTERVAL_SECONDS=1
CLEANUP_TG_SEND_DOCUMENT_MIN_INTERVAL_SECONDS=15
CLEANUP_TG_MAX_RETRIES=5
